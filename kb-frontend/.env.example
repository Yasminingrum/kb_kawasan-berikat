# kb-frontend/.env
# =============================================================
# Environment Variables — kb-frontend v3
# =============================================================
# JANGAN commit file ini ke Git. Pastikan .gitignore sudah
# mencantumkan .env
#
# Cara mengisi:
#   1. VITE_MASTER_REGISTRY_ADDRESS:
#      Jalankan: npx hardhat ignition deploy ./ignition/modules/deploy.ts
#      Salin alamat MasterRegistry_v3 dari output terminal
#
#   2. VITE_FIREBASE_*:
#      Buka: https://console.firebase.google.com
#      Project Settings → General → Your apps → Web app
#      Salin setiap nilai dari firebaseConfig
#
# Setelah mengisi, restart dev server: npm run dev
# =============================================================

# ── Blockchain ────────────────────────────────────────────────
# Alamat MasterRegistry_v3 yang sudah di-deploy di Hardhat local
# Update setiap kali melakukan deploy ulang
VITE_MASTER_REGISTRY_ADDRESS=0x_GANTI_DENGAN_ALAMAT_MASTERREGISTRY_V3

# ── Firebase ──────────────────────────────────────────────────
# Salin dari Firebase Console → Project Settings → Your apps → Web
VITE_FIREBASE_API_KEY=AIza_GANTI_DENGAN_API_KEY_FIREBASE
VITE_FIREBASE_AUTH_DOMAIN=nama-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nama-project
VITE_FIREBASE_STORAGE_BUCKET=nama-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456
