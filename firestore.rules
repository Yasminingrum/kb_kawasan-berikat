rules_version = '2';

// ================================================================
// Firestore Security Rules — Sistem IT Inventory Kawasan Berikat
// v4: Tambah akses ke sub-collection "katalog"
//
// Struktur path:
//   kawasan_berikat/{idKB}/barang_masuk/{docId}
//   kawasan_berikat/{idKB}/barang_keluar/{docId}
//   kawasan_berikat/{idKB}/scrap/{docId}
//   kawasan_berikat/{idKB}/pemusnahan/{docId}
//   kawasan_berikat/{idKB}/wip/{docId}
//   kawasan_berikat/{idKB}/hasil_produksi/{docId}
//   kawasan_berikat/{idKB}/bom/{docId}
//   kawasan_berikat/{idKB}/stock_opname/{docId}
//   kawasan_berikat/{idKB}/audit_log/{docId}
//   kawasan_berikat/{idKB}/katalog/{kodeBarangInternal}  ← v4 baru
//
// Catatan sistem ini menggunakan wallet address (MetaMask)
// sebagai identitas, bukan Firebase Auth. Rules ini bersifat
// permissive untuk mendukung arsitektur wallet-based tersebut.
// Autentikasi sesungguhnya terjadi di smart contract (onlyAuthorized).
// ================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Kawasan Berikat (dokumen induk) ─────────────────────
    match /kawasan_berikat/{idKB} {
      allow read, write: if true;

      // ── Semua sub-collection per KB ──────────────────────
      // Ini mencakup: barang_masuk, barang_keluar, scrap,
      // pemusnahan, wip, hasil_produksi, bom, stock_opname,
      // audit_log, DAN katalog (v4)
      match /{subCollection}/{docId} {
        allow read, write: if true;
      }
    }
  }
}
