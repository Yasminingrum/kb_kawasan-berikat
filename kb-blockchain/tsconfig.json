{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": [
    "contracts/**/*",
    "scripts/**/*",
    "test/**/*",
    "ignition/**/*",
    "hardhat.config.ts"
  ]
}